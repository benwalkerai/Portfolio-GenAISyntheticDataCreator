# Local LLM Configuration
# Base URL for the OpenAI-compatible API (e.g., Ollama or llama.cpp)
LLM_API_BASE=<LLM-ENDPOINT> # Change this

# API Key
# For local Ollama/llama.cpp server this can usually be any string, e.g. 'ollama'
LLM_API_KEY=<KEY> # Enter your key here

# Model Name
# This must match the model you have pulled/loaded in your local server
# Examples: llama3.1:8b, mistral:7b, qwen2.5:14b-instruct-q4_k_m
LLM_MODEL=<MODEL> # Change this